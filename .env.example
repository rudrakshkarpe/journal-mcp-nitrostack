# Optional. Defaults to Amadeus test environment.
AMADEUS_BASE_URL=https://test.api.amadeus.com

# Optional. When omitted, the server returns deterministic mock flight offers.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# Optional. Used for live flight status/schedule data. Does not return fares.
AVIATIONSTACK_BASE_URL=http://api.aviationstack.com/v1
AVIATIONSTACK_API_KEY=
